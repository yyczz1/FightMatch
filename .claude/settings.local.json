{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Edit(/Assets/**)",
      "Edit(/Packages/**)",
      "Edit(/ProjectSettings/**)",
      "Edit(/.claude/**)",
      "Edit(/CLAUDE.md)",
      "Edit(/.gitignore)",
      "PowerShell(Get-Location)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Push-Location *)",
      "PowerShell(Pop-Location)",
      "PowerShell(Set-Location *)",
      "PowerShell(git status *)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)",
      "PowerShell(git branch *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(New-Item *)",
      "PowerShell(Copy-Item *)",
      "PowerShell(Move-Item *)",
      "PowerShell(dotnet build *)",
      "PowerShell(dotnet test *)",
      "PowerShell(python *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(dotnet build *)",
      "Bash(dotnet test *)",
      "Bash(python *)",
      "mcp__serena__initial_instructions",
      "Bash(git *)",
      "Bash(echo \"EXIT:$?\")",
      "PowerShell(git *)",
      "PowerShell(Get-ChildItem -Path \"D:\\\\Unity\\\\UnityProj\\\\FightMatch\\\\ProjectSettings\" -Filter \"ProjectVersion.txt\" | ForEach-Object { Get-Content $_.FullName })",
      "PowerShell($item = Get-Item \"D:\\\\Unity\\\\UnityProj\\\\FightMatch\\\\.git\" -Force; \"Type: $\\($item.GetType\\(\\).Name\\)\"; \"Attributes: $\\($item.Attributes\\)\"; if \\($item -is [System.IO.DirectoryInfo]\\) { \"Is directory: True\"; Get-ChildItem $item.FullName -Force | Select-Object Name, Length, Mode } else { \"Is directory: False\"; \"Content: $\\($item.Length\\) bytes\" })",
      "PowerShell(cmd /c \"rmdir /s /q D:\\\\Unity\\\\UnityProj\\\\FightMatch\\\\.git\")",
      "PowerShell(git init *)",
      "Write(/Assets/**)",
      "Write(/Packages/**)",
      "Write(/ProjectSettings/**)",
      "Write(/.claude/**)",
      "Write(/.gitignore)",
      "Write(/CLAUDE.md)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(secrets/**)",
      "Read(/Library/**)",
      "Read(/Temp/**)",
      "Read(/UserSettings/**)",
      "Edit(/Library/**)",
      "Edit(/Temp/**)",
      "Edit(/UserSettings/**)",
      "Edit(/.git/**)",
      "PowerShell(Remove-Item *)",
      "PowerShell(ri *)",
      "PowerShell(del *)",
      "PowerShell(rmdir *)",
      "PowerShell(git push --force *)",
      "PowerShell(git reset --hard *)",
      "PowerShell(git clean -fd *)",
      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(Invoke-RestMethod *)",
      "PowerShell(iwr *)",
      "PowerShell(irm *)",
      "PowerShell(*Unity* add package *)",
      "PowerShell(*Unity* install *)",
      "PowerShell(*Unity* upgrade *)",
      "PowerShell(*npm install *)",
      "PowerShell(*dotnet add package *)",
      "Bash(*Unity* add package *)",
      "Bash(*Unity* install *)",
      "Bash(*Unity* upgrade *)",
      "Bash(*npm install *)",
      "Bash(*dotnet add package *)",
      "Bash(rm -rf *)",
      "Bash(del *)",
      "Bash(rmdir *)",
      "Bash(format *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)"
    ],
    "ask": [
      "PowerShell(git push *)",
      "PowerShell(*Unity* -buildTarget *)",
      "PowerShell(*Unity* -executeMethod *Build*)",
      "PowerShell(*Unity* -executeMethod *Deploy*)",
      "PowerShell(*Unity* -executeMethod *Publish*)",
      "PowerShell(Unity.exe *)",
      "PowerShell(*Unity* -batchmode *)",
      "PowerShell(*Unity* -quit *)",
      "Bash(git push *)",
      "Bash(*Unity* -buildTarget *)",
      "Bash(*Unity* -executeMethod *Build*)",
      "Bash(*Unity* -executeMethod *Deploy*)",
      "Bash(*Unity* -executeMethod *Publish*)",
      "Bash(Unity.exe *)",
      "Bash(*Unity* -batchmode *)",
      "Bash(*Unity* -quit *)"
    ],
    "defaultMode": "acceptEdits"
  }
}
